{
  "name": "ROS 2 Drone Workspace",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "drone_ros_ws", // Usa il nome esatto del servizio ROS 2 definito nel tuo docker-compose.yml
  "workspaceFolder": "/percorso/interno/al/container/drone_ros_ws", // Es: /workspace/drone_ros_ws
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-themes"
      ],
      "settings": {
        "C_Cpp.default.compileCommands": "${workspaceFolder}/build/drone_core/compile_commands.json",
        "C_Cpp.default.intelliSenseMode": "linux-gcc-x64"
      }
    }
  }
}